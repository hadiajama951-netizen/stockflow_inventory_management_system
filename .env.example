PORT=3000
SESSION_SECRET=change_this_to_a_random_secret_string
DEFAULT_SHOP_NAME=Your Shop Name
DEFAULT_CURRENCY=$

# ---- Optional: public live demo mode ----
# Only set this to true on a public demo deployment (e.g. for marketplace
# reviewers/buyers to try). It seeds two demo accounts (owner@demo.com and
# staff@demo.com, both password123) plus sample products, and automatically
# wipes/reseeds that data every 24 hours. Leave this blank or "false" for
# your own real shop -- you'll set up your own owner account instead.
DEMO_MODE=false

# ---- Optional: email settings, only needed for "Forgot Password" emails ----
# If you leave these blank, password reset still works, but staff will be
# told to ask the shop owner to reset it manually from Staff Accounts.
# Example values below are for a Gmail account using an "App Password"
# (not your normal Gmail password -- search "Gmail app password" to create one).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
