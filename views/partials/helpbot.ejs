<!-- Help Assistant: a small, free, built-in Q&A widget. No AI service,
     no API key, no ongoing cost -- just pre-written answers matched by
     keyword. It only answers questions and points people to features;
     it never performs actions on the person's behalf. -->
<div id="helpbot-bubble" title="Need help?">?</div>

<div id="helpbot-panel">
  <div id="helpbot-header">
    <span>Help Assistant</span>
    <button id="helpbot-close" aria-label="Close">&times;</button>
  </div>
  <div id="helpbot-messages"></div>
  <form id="helpbot-form">
    <input type="text" id="helpbot-input" placeholder="Ask a question..." autocomplete="off">
    <button type="submit">Send</button>
  </form>
</div>

<script src="/js/helpbot-data.js"></script>
<script>
(function () {
  const bubble = document.getElementById('helpbot-bubble');
  const panel = document.getElementById('helpbot-panel');
  const closeBtn = document.getElementById('helpbot-close');
  const messages = document.getElementById('helpbot-messages');
  const form = document.getElementById('helpbot-form');
  const input = document.getElementById('helpbot-input');

  function addMessage(text, from) {
    const div = document.createElement('div');
    div.className = 'helpbot-msg helpbot-' + from;
    div.textContent = text;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  let greeted = false;

  bubble.addEventListener('click', function () {
    panel.classList.toggle('helpbot-open');
    if (!greeted) {
      addMessage("Hi! I can help you find features in this system. Try asking things like 'how do I add a product' or 'how do I change the currency'.", 'bot');
      greeted = true;
    }
  });

  closeBtn.addEventListener('click', function () {
    panel.classList.remove('helpbot-open');
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    addMessage(text, 'user');
    input.value = '';
    setTimeout(function () {
      addMessage(helpbotFindAnswer(text), 'bot');
    }, 300);
  });
})();
</script>
