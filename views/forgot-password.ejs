<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Forgot Password — ' + shopName }) %>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="brand">StockFlow</div>
      <h1>Reset your password</h1>

      <% if (message) { %>
        <div class="error-msg" style="background:#e7f3ec; color:var(--accent-dark);"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>

      <% if (!message) { %>
        <form method="POST" action="/forgot-password">
          <div class="field">
            <label for="email">Your account email</label>
            <input type="email" id="email" name="email" required autofocus>
          </div>
          <button type="submit" class="btn btn-block">Send Reset Link</button>
        </form>
      <% } %>

      <div class="auth-footer">
        <a href="/login">Back to login</a>
      </div>
    </div>
  </div>
</body>
</html>
