<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Set New Password' }) %>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="brand">StockFlow</div>
      <h1>Set a new password</h1>

      <% if (error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>

      <form method="POST" action="/reset-password/<%= token %>">
        <div class="field">
          <label for="password">New password</label>
          <input type="password" id="password" name="password" required minlength="6" autofocus>
        </div>
        <button type="submit" class="btn btn-block">Set New Password</button>
      </form>
    </div>
  </div>
</body>
</html>
