<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Log in — ' + shopName }) %>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="brand">StockFlow</div>
      <h1><%= shopName %></h1>

      <% if (typeof message !== 'undefined' && message) { %>
        <div class="error-msg" style="background:#e7f3ec; color:var(--accent-dark);"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>

      <% if (typeof demoMode !== 'undefined' && demoMode) { %>
        <div class="error-msg" style="background:#eef5ff; color:#1f4e8c; text-align:left; line-height:1.5;">
          <strong>This is a live demo.</strong> Try either account below:<br>
          Owner — owner@demo.com / password123<br>
          Staff — staff@demo.com / password123<br>
          Demo data resets automatically every 24 hours.
        </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autofocus>
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required>
        </div>
        <button type="submit" class="btn btn-block">Log in</button>
      </form>

      <div class="auth-footer">
        <a href="/forgot-password">Forgot your password?</a>
      </div>
    </div>
  </div>
</body>
</html>
