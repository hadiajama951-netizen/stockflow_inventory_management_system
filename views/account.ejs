<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'My Account' }) %>
<body>
  <div class="app">
    <%- include('partials/sidebar', { active: 'account', shopName: '', userName, userRole }) %>

    <div class="main">
      <div class="page-header">
        <h1>My Account</h1>
      </div>

      <% if (saved) { %>
        <div class="error-msg" style="background:#e7f3ec; color:var(--accent-dark);">Password updated.</div>
      <% } %>
      <% if (error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>

      <div class="card" style="max-width:500px;">
        <h2>Change Password</h2>
        <p style="color: var(--muted); font-size: 13px; margin-top:-8px; margin-bottom:16px;">
          Logged in as <%= userName %> (<%= userRole === 'owner' ? 'Admin' : 'Staff' %>).
        </p>
        <form method="POST" action="/account/change-password">
          <input type="hidden" name="return_to" value="/account">
          <div class="field">
            <label for="current_password">Current password</label>
            <input type="password" id="current_password" name="current_password" required>
          </div>
          <div class="field">
            <label for="new_password">New password</label>
            <input type="password" id="new_password" name="new_password" required minlength="6">
          </div>
          <div class="field">
            <label for="confirm_password">Confirm new password</label>
            <input type="password" id="confirm_password" name="confirm_password" required minlength="6">
          </div>
          <button type="submit" class="btn">Update Password</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
