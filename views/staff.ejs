<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Staff Accounts' }) %>
<body>
  <div class="app">
    <%- include('partials/sidebar', { active: 'staff', shopName: '', userName, userRole }) %>

    <div class="main">
      <div class="page-header">
        <h1>Staff Accounts</h1>
        <div class="dropdown">
          <button type="button" class="btn btn-secondary" data-dropdown-trigger>Download ▾</button>
          <div class="dropdown-menu">
            <a href="/staff/export/all/csv">Entire Staff List — CSV</a>
          </div>
        </div>
      </div>

      <% if (error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>

      <div class="card" style="max-width:500px;">
        <h2>Add Staff Member</h2>
        <form method="POST" action="/staff/new">
          <div class="field">
            <label for="name">Full name</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="field">
            <label for="password">Temporary password</label>
            <input type="password" id="password" name="password" required minlength="6">
          </div>
          <div class="field">
            <label for="role">Role</label>
            <select id="role" name="role">
              <option value="Staff">Staff</option>
              <option value="Admin">Admin</option>
            </select>
          </div>
          <button type="submit" class="btn">Add Staff Member</button>
        </form>
      </div>

      <div class="card">
        <h2>Owners / Admins</h2>
        <% if (owners.length === 0) { %>
          <div class="empty-state">No admin accounts.</div>
        <% } else { %>
          <table>
            <thead>
              <tr><th>Name</th><th>Email</th><th>Role</th><th></th></tr>
            </thead>
            <tbody>
              <% owners.forEach(function(s) { %>
                <tr>
                  <td><%= s.name %></td>
                  <td><%= s.email %></td>
                  <td><span class="badge ok">Admin</span></td>
                  <td>
                    <div class="row-actions">
                      <a href="/staff/<%= s.id %>/edit">Edit</a>
                      <div class="dropdown">
                        <button type="button" class="btn-secondary btn btn-tiny" data-dropdown-trigger>Download ▾</button>
                        <div class="dropdown-menu">
                          <a href="/staff/<%= s.id %>/export/pdf">This Employee — PDF</a>
                          <a href="/staff/export/all/csv">Entire Staff List — CSV</a>
                        </div>
                      </div>
                      <% if (s.id !== currentUserId) { %>
                        <form action="/staff/<%= s.id %>/delete" method="POST"
                          onsubmit="return confirm('Remove this account?');">
                          <button type="submit" class="btn-secondary btn btn-tiny">Delete</button>
                        </form>
                      <% } else { %>
                        <span style="color: var(--muted); font-size:13px;">You</span>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>

      <div class="card">
        <h2>Staff Members</h2>
        <input type="text" id="staff-search" class="live-search" placeholder="Search staff by name...">
        <% if (staffList.length === 0) { %>
          <div class="empty-state">No staff members yet.</div>
        <% } else { %>
          <table id="staff-table">
            <thead>
              <tr><th>Name</th><th>Email</th><th>Role</th><th></th></tr>
            </thead>
            <tbody>
              <% staffList.forEach(function(s) { %>
                <tr data-name="<%= s.name.toLowerCase() %>">
                  <td><%= s.name %></td>
                  <td><%= s.email %></td>
                  <td><span class="badge">Staff</span></td>
                  <td>
                    <div class="row-actions">
                      <a href="/staff/<%= s.id %>/edit">Edit</a>
                      <div class="dropdown">
                        <button type="button" class="btn-secondary btn btn-tiny" data-dropdown-trigger>Download ▾</button>
                        <div class="dropdown-menu">
                          <a href="/staff/<%= s.id %>/export/pdf">This Employee — PDF</a>
                          <a href="/staff/export/all/csv">Entire Staff List — CSV</a>
                        </div>
                      </div>
                      <form action="/staff/<%= s.id %>/delete" method="POST"
                        onsubmit="return confirm('Remove this account?');">
                        <button type="submit" class="btn-secondary btn btn-tiny">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
          <div class="empty-state" id="staff-no-results" style="display:none;">No staff match your search.</div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    const staffSearch = document.getElementById('staff-search');
    if (staffSearch) {
      staffSearch.addEventListener('input', function () {
        const term = staffSearch.value.trim().toLowerCase();
        const rows = document.querySelectorAll('#staff-table tbody tr');
        let visibleCount = 0;
        rows.forEach(function (row) {
          const match = row.dataset.name.includes(term);
          row.style.display = match ? '' : 'none';
          if (match) visibleCount++;
        });
        const noResults = document.getElementById('staff-no-results');
        if (noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      });
    }
  </script>
</body>
</html>
